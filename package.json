{
  "name": "memolens-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron-dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "tsc --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "electron": "npm run build && electron --no-sandbox .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^37.2.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
